MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/guruapi?retryWrites=true&w=majority
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
CORS_ALLOW_PRIVATE_NETWORK=false
LOG_LEVEL=info
REQUEST_WINDOW_MS=900000
REQUEST_LIMIT=200
REQUEST_BODY_LIMIT=2mb
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
SEED_ADMIN_ON_BOOT=false
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123
AI_PROVIDER=gemini
OPENAI_API_KEY=
# OpenAI-compatible servers (e.g. local) should include `/v1`:
# OPENAI_BASE_URL=http://localhost:1234/v1
# If your local server uses a different chat endpoint:
# OPENAI_CHAT_PATH=/api/v1/chat
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
# Example models:
# - gemini-3.1-flash-lite
# - gemini-3.1-flash
# - gemini-2.0-flash-lite
# - gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MATH_MODEL=gemini-2.0-flash
GEMINI_BULK_MODEL=gemini-2.0-flash-lite
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-3.1-flash,gemini-2.0-flash-lite,gemini-2.0-flash
QUESTION_BANK_MODE=hybrid
QUESTION_BANK_MIN_VALID_FIELDS=question,options,answer
QUESTION_BANK_DIAGNOSTICS_ENABLED=true
QUESTION_ASSEMBLY_MODE=flex
QUESTION_BANK_RECENT_EXCLUDE_COUNT=120
QUESTION_BANK_APPROVED_ONLY=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=120
AI_RATE_LIMIT_MAX=60
WRITE_RATE_LIMIT_MAX=180
AI_JOB_CREATE_RATE_LIMIT_MAX=400
WORKER_SECRET=
METRICS_SECRET=
